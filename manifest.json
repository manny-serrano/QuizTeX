{
  "manifest_version": 3,
  "name": "Quizlet LaTeX Renderer",
  "version": "1.7.0",
  "description": "Automatically renders LaTeX equations on Quizlet so you can read math and physics formulas clearly.",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://*.quizlet.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.quizlet.com/*"],
      "js": ["content.js", "tex-chtml.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["tex-chtml.js"],
      "matches": ["https://*.quizlet.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}

{
  "manifest_version": 3,
  "name": "Quizlet LaTeX Renderer",
  "version": "1.10.0",
  "description": "Automatically renders LaTeX equations on Quizlet so you can read math and physics formulas clearly.",
  "host_permissions": [
    "https://*.quizlet.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.quizlet.com/*"],
      "js": ["content.js", "tex-svg.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["tex-svg.js"],
      "matches": ["https://*.quizlet.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
